{
  "title": "Quality Dashboard",
  "uid": "quality-001",
  "tags": ["adaptive-quality", "quality"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Precision over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "PCC52D03280B7034C" },
      "targets": [
        {
          "rawSql": "SELECT snapshot_at AS time, precision AS value FROM quality_snapshots WHERE snapshot_at >= $__timeFrom() AND snapshot_at <= $__timeTo() ORDER BY snapshot_at",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": 0    },
              { "color": "yellow", "value": 0.75 },
              { "color": "green",  "value": 0.90 }
            ]
          },
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      }
    },
    {
      "id": 2,
      "title": "Recall over Time",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "PCC52D03280B7034C" },
      "targets": [
        {
          "rawSql": "SELECT snapshot_at AS time, recall AS value FROM quality_snapshots WHERE snapshot_at >= $__timeFrom() AND snapshot_at <= $__timeTo() ORDER BY snapshot_at",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      }
    },
    {
      "id": 3,
      "title": "Current Precision",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 6 },
      "datasource": { "type": "postgres", "uid": "PCC52D03280B7034C" },
      "targets": [
        {
          "rawSql": "SELECT precision AS value FROM quality_snapshots ORDER BY snapshot_at DESC LIMIT 1",
          "format": "table"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": 0    },
              { "color": "yellow", "value": 0.75 },
              { "color": "green",  "value": 0.90 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Current Recall",
      "type": "gauge",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 6 },
      "datasource": { "type": "postgres", "uid": "PCC52D03280B7034C" },
      "targets": [
        {
          "rawSql": "SELECT recall AS value FROM quality_snapshots ORDER BY snapshot_at DESC LIMIT 1",
          "format": "table"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": 0    },
              { "color": "yellow", "value": 0.70 },
              { "color": "green",  "value": 0.85 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Current F1",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 6 },
      "datasource": { "type": "postgres", "uid": "PCC52D03280B7034C" },
      "targets": [
        {
          "rawSql": "SELECT f1 AS value FROM quality_snapshots ORDER BY snapshot_at DESC LIMIT 1",
          "format": "table"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": 0    },
              { "color": "yellow", "value": 0.75 },
              { "color": "green",  "value": 0.88 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Reversal Rate",
      "type": "gauge",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 6 },
      "datasource": { "type": "postgres", "uid": "PCC52D03280B7034C" },
      "targets": [
        {
          "rawSql": "SELECT reversal_rate AS value FROM quality_snapshots ORDER BY snapshot_at DESC LIMIT 1",
          "format": "table"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": 0    },
              { "color": "yellow", "value": 0.05 },
              { "color": "red",    "value": 0.15 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Precision / Recall by Tier",
      "type": "table",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "PCC52D03280B7034C" },
      "targets": [
        {
          "rawSql": "SELECT tier, ROUND(COUNT(*) FILTER (WHERE predicted = 'positive' AND ground_truth = 'positive')::numeric / NULLIF(COUNT(*) FILTER (WHERE predicted = 'positive'), 0), 4) AS precision, ROUND(COUNT(*) FILTER (WHERE predicted = 'positive' AND ground_truth = 'positive')::numeric / NULLIF(COUNT(*) FILTER (WHERE predicted = 'positive' AND ground_truth = 'positive') + COUNT(*) FILTER (WHERE predicted = 'negative' AND ground_truth = 'positive'), 0), 4) AS recall, COUNT(*) AS total FROM decisions WHERE ground_truth IS NOT NULL GROUP BY tier",
          "format": "table"
        }
      ]
    },
    {
      "id": 8,
      "title": "Reversal Rate by Category",
      "type": "barchart",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "PCC52D03280B7034C" },
      "targets": [
        {
          "rawSql": "SELECT category, ROUND(AVG(reversed::int)::numeric, 4) AS reversal_rate FROM decisions GROUP BY category ORDER BY reversal_rate DESC",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": 0    },
              { "color": "yellow", "value": 0.05 },
              { "color": "red",    "value": 0.15 }
            ]
          }
        }
      }
    }
  ]
}
